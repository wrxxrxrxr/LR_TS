{
    "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "Bundler",
      "strict": true,
      "noImplicitAny": true,
      "strictNullChecks": true,
      "allowJs": true,
      "checkJs": false,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "lib": [
        "ES2020",
        "DOM"
      ],
      "types": [
        "node"
      ]
    },
    "include": [
      "src/**/*",
      "*.ts",
      "*.d.ts"
    ]
  }